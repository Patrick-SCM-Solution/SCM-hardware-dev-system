<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>漢字 SRS — Patrick's Vocab Desk</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,600;1,400&family=Noto+Sans+TC:wght@400;700&family=Sora:wght@300;500;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0b0c0e;
  --surface: #13151a;
  --surface2: #1a1d24;
  --surface3: #22262f;
  --border: #272b35;
  --border2: #333844;
  --accent: #e8c547;
  --accent-dim: rgba(232,197,71,0.12);
  --green: #4ec994;
  --green-dim: rgba(78,201,148,0.12);
  --blue: #5b9fe8;
  --blue-dim: rgba(91,159,232,0.12);
  --red: #e05a5a;
  --red-dim: rgba(224,90,90,0.12);
  --orange: #e0905a;
  --text: #dde1ea;
  --text2: #9aa0ad;
  --text3: #5a6070;
  --zh: 'Noto Sans TC', sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:'Sora',sans-serif;}

/* ── LAYOUT ── */
.app{display:grid;grid-template-rows:auto 1fr;height:100vh;overflow:hidden;}
header{
  display:flex;align-items:center;justify-content:space-between;
  padding:0 28px;height:52px;
  background:var(--surface);border-bottom:1px solid var(--border);
  position:relative;z-index:10;
}
.logo{
  font-family:'IBM Plex Mono',monospace;font-size:12px;
  letter-spacing:0.12em;color:var(--accent);text-transform:uppercase;
}
.logo em{color:var(--text3);font-style:normal;}
nav{display:flex;gap:4px;}
.tab{
  background:none;border:1px solid transparent;color:var(--text3);
  padding:5px 14px;border-radius:6px;cursor:pointer;
  font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.06em;
  transition:all .15s;text-transform:uppercase;
}
.tab:hover{color:var(--text);border-color:var(--border2);}
.tab.active{color:var(--accent);border-color:var(--accent);background:var(--accent-dim);}

.body{display:flex;overflow:hidden;}
.sidebar{
  width:220px;flex-shrink:0;border-right:1px solid var(--border);
  background:var(--surface);padding:20px 0;display:flex;flex-direction:column;gap:2px;
}
.sidebar-btn{
  display:flex;align-items:center;gap:10px;padding:9px 20px;
  color:var(--text3);cursor:pointer;font-size:12px;
  transition:all .15s;border:none;background:none;width:100%;text-align:left;
  border-left:2px solid transparent;
}
.sidebar-btn:hover{color:var(--text);background:var(--surface2);}
.sidebar-btn.active{color:var(--accent);background:var(--accent-dim);border-left-color:var(--accent);}
.sidebar-btn .icon{font-size:15px;width:20px;text-align:center;}
.sidebar-section{
  padding:16px 20px 6px;font-family:'IBM Plex Mono',monospace;
  font-size:9px;color:var(--text3);letter-spacing:0.12em;text-transform:uppercase;
}
.sidebar-divider{height:1px;background:var(--border);margin:10px 16px;}

.content{flex:1;overflow-y:auto;padding:32px;}

/* ── VIEWS ── */
.view{display:none;max-width:780px;margin:0 auto;}
.view.active{display:block;}

/* ── STUDY VIEW ── */
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px;}
.stat{
  background:var(--surface);border:1px solid var(--border);
  border-radius:10px;padding:16px;text-align:center;
}
.stat .n{
  font-family:'IBM Plex Mono',monospace;font-size:30px;font-weight:600;
  color:var(--accent);line-height:1;
}
.stat .l{font-size:10px;color:var(--text3);margin-top:5px;text-transform:uppercase;letter-spacing:.07em;}

.prog-wrap{background:var(--surface3);border-radius:3px;height:3px;margin-bottom:28px;overflow:hidden;}
.prog-bar{height:100%;background:var(--accent);border-radius:3px;transition:width .4s ease;}

.study-card{
  background:var(--surface);border:1px solid var(--border);border-radius:16px;
  padding:52px 44px;min-height:300px;display:flex;flex-direction:column;
  align-items:center;justify-content:center;gap:18px;position:relative;
  transition:border-color .2s;margin-bottom:16px;
}
.study-card:hover{border-color:var(--border2);}
.card-tag{
  position:absolute;top:16px;left:16px;
  font-family:'IBM Plex Mono',monospace;font-size:9px;
  color:var(--green);border:1px solid rgba(78,201,148,.3);
  border-radius:4px;padding:2px 8px;letter-spacing:.07em;text-transform:uppercase;
}
.card-pos{
  position:absolute;top:16px;right:16px;
  font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--text3);
}
.en-prompt{font-size:24px;font-weight:700;color:var(--text);text-align:center;}
.answer-wrap{
  display:flex;flex-direction:column;align-items:center;gap:10px;
  filter:blur(10px);transition:filter .3s;cursor:pointer;user-select:none;
}
.answer-wrap.revealed{filter:none;cursor:default;}
.answer-wrap:not(.revealed):hover{filter:blur(5px);}
.zh-big{font-family:var(--zh);font-size:56px;font-weight:700;color:var(--text);line-height:1.1;}
.pinyin-line{font-family:'IBM Plex Mono',monospace;font-size:15px;color:var(--accent);letter-spacing:.04em;}
.reveal-hint{font-size:10px;color:var(--text3);font-family:'IBM Plex Mono',monospace;letter-spacing:.06em;}

.reveal-cta{
  background:var(--surface2);border:1px solid var(--border2);color:var(--text2);
  font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:.1em;text-transform:uppercase;
  padding:12px 32px;border-radius:8px;cursor:pointer;transition:all .15s;
  display:flex;align-items:center;gap:8px;
}
.reveal-cta:hover{border-color:var(--accent);color:var(--accent);background:var(--accent-dim);}

.rating-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:4px;}
.r-btn{
  padding:14px 6px;border-radius:10px;border:1px solid var(--border);
  background:var(--surface);cursor:pointer;transition:all .15s;
  display:flex;flex-direction:column;align-items:center;gap:5px;
}
.r-btn:hover{transform:translateY(-3px);box-shadow:0 8px 24px rgba(0,0,0,.3);}
.r-btn .rn{font-family:'IBM Plex Mono',monospace;font-size:22px;font-weight:600;}
.r-btn .rl{font-size:9px;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);}
.r-btn.q0{border-color:var(--red);} .r-btn.q0:hover{background:var(--red-dim);} .r-btn.q0 .rn{color:var(--red);}
.r-btn.q1{border-color:var(--orange);} .r-btn.q1:hover{background:rgba(224,144,90,.12);} .r-btn.q1 .rn{color:var(--orange);}
.r-btn.q2{border-color:var(--blue);} .r-btn.q2:hover{background:var(--blue-dim);} .r-btn.q2 .rn{color:var(--blue);}
.r-btn.q3{border-color:var(--green);} .r-btn.q3:hover{background:var(--green-dim);} .r-btn.q3 .rn{color:var(--green);}

.sentence-card{
  background:var(--surface);border:1px solid var(--border);border-radius:12px;
  padding:22px 28px;margin-top:4px;
}
.sentence-zh{font-family:var(--zh);font-size:16px;color:var(--text);margin-bottom:6px;line-height:1.7;}
.sentence-en{font-size:12px;color:var(--text3);line-height:1.6;}

.complete-box{
  background:var(--surface);border:1px solid var(--border);border-radius:16px;
  padding:60px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:14px;
}
.complete-box .big{font-size:52px;}
.complete-box h2{font-size:20px;font-weight:700;}
.complete-box p{font-size:13px;color:var(--text3);max-width:360px;line-height:1.8;}

/* ── LIBRARY VIEW ── */
.lib-toolbar{
  display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;gap:12px;
}
.lib-search{
  flex:1;background:var(--surface);border:1px solid var(--border);
  color:var(--text);padding:9px 14px;border-radius:8px;
  font-family:'Sora',sans-serif;font-size:13px;outline:none;transition:border-color .15s;
}
.lib-search:focus{border-color:var(--accent);}
.lib-search::placeholder{color:var(--text3);}
.cat-filter{
  background:var(--surface);border:1px solid var(--border);color:var(--text2);
  padding:9px 12px;border-radius:8px;font-size:12px;outline:none;cursor:pointer;
  font-family:'IBM Plex Mono',monospace;
}
.cat-filter:focus{border-color:var(--accent);}

.lib-table{width:100%;border-collapse:collapse;}
.lib-table thead tr{border-bottom:1px solid var(--border);}
.lib-table th{
  padding:8px 12px;text-align:left;font-family:'IBM Plex Mono',monospace;
  font-size:9px;color:var(--text3);letter-spacing:.1em;text-transform:uppercase;font-weight:400;
}
.lib-table tbody tr{border-bottom:1px solid var(--border);transition:background .1s;}
.lib-table tbody tr:hover{background:var(--surface2);}
.lib-table td{padding:12px 12px;font-size:13px;vertical-align:middle;}
.td-zh{font-family:var(--zh);font-size:18px;font-weight:700;}
.td-py{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--accent);margin-top:2px;}
.td-cat{
  font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--green);
  border:1px solid rgba(78,201,148,.25);border-radius:3px;padding:2px 7px;
  letter-spacing:.05em;text-transform:uppercase;display:inline-block;
}
.td-due{font-family:'IBM Plex Mono',monospace;font-size:10px;}
.due-now{color:var(--red);}
.due-soon{color:var(--accent);}
.due-ok{color:var(--text3);}
.row-del{
  background:none;border:1px solid var(--border);color:var(--text3);
  font-size:11px;padding:3px 9px;border-radius:4px;cursor:pointer;transition:all .15s;
}
.row-del:hover{border-color:var(--red);color:var(--red);}

/* ── IMPORT VIEW ── */
.import-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:32px;}
.import-card{
  background:var(--surface);border:1px solid var(--border);border-radius:12px;
  padding:24px;cursor:pointer;transition:all .2s;
  display:flex;flex-direction:column;gap:10px;
}
.import-card:hover{border-color:var(--accent);background:var(--accent-dim);}
.import-card.wide{grid-column:1/-1;}
.import-card .ic-icon{font-size:28px;}
.import-card h3{font-size:14px;font-weight:700;}
.import-card p{font-size:12px;color:var(--text3);line-height:1.6;}

.import-panel{display:none;flex-direction:column;gap:16px;}
.import-panel.open{display:flex;}
.panel-header{display:flex;align-items:center;justify-content:space-between;}
.panel-title{font-size:16px;font-weight:700;}
.panel-close{
  background:none;border:1px solid var(--border);color:var(--text3);
  padding:5px 12px;border-radius:6px;cursor:pointer;font-size:11px;
  font-family:'IBM Plex Mono',monospace;transition:all .15s;
}
.panel-close:hover{border-color:var(--text);color:var(--text);}

textarea.import-ta{
  background:var(--surface2);border:1px solid var(--border);
  color:var(--text);padding:14px;border-radius:8px;
  font-family:'IBM Plex Mono',monospace;font-size:12px;line-height:1.7;
  resize:vertical;min-height:180px;outline:none;transition:border-color .15s;
  width:100%;
}
textarea.import-ta:focus{border-color:var(--accent);}
textarea.import-ta::placeholder{color:var(--text3);}

.import-hint{
  background:var(--surface2);border:1px solid var(--border);border-radius:8px;
  padding:14px;font-family:'IBM Plex Mono',monospace;font-size:11px;
  color:var(--text3);line-height:1.8;
}
.import-hint strong{color:var(--accent);}

.file-drop{
  border:2px dashed var(--border2);border-radius:10px;padding:40px;
  text-align:center;cursor:pointer;transition:all .2s;display:flex;
  flex-direction:column;align-items:center;gap:10px;
}
.file-drop:hover,.file-drop.dragover{border-color:var(--accent);background:var(--accent-dim);}
.file-drop .drop-icon{font-size:32px;}
.file-drop p{font-size:13px;color:var(--text3);}
.file-drop em{font-size:11px;color:var(--text3);font-style:normal;font-family:'IBM Plex Mono',monospace;}
#csv-file-input{display:none;}

.preview-table-wrap{
  background:var(--surface2);border:1px solid var(--border);border-radius:8px;
  overflow:auto;max-height:240px;
}
.preview-table{width:100%;border-collapse:collapse;font-size:12px;}
.preview-table th{
  padding:8px 12px;background:var(--surface3);font-family:'IBM Plex Mono',monospace;
  font-size:9px;color:var(--text3);letter-spacing:.1em;text-transform:uppercase;
  position:sticky;top:0;
}
.preview-table td{padding:8px 12px;border-top:1px solid var(--border);vertical-align:middle;}
.preview-table .pv-zh{font-family:var(--zh);font-size:15px;font-weight:700;}
.preview-table .pv-check{color:var(--green);font-size:14px;}
.preview-table .pv-warn{color:var(--orange);font-size:12px;}

.import-actions{display:flex;gap:10px;align-items:center;}
.import-count{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--text3);}

/* ── ADD SINGLE VIEW ── */
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.form-grid.full{grid-template-columns:1fr;}
.field{display:flex;flex-direction:column;gap:6px;}
.field label{font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--text3);text-transform:uppercase;letter-spacing:.1em;}
.field input,.field select,.field textarea{
  background:var(--surface2);border:1px solid var(--border);color:var(--text);
  padding:10px 13px;border-radius:8px;font-family:'Sora',sans-serif;font-size:14px;
  outline:none;transition:border-color .15s;
}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--accent);}
.field textarea{resize:vertical;min-height:72px;}
.field select option{background:var(--surface2);}

/* ── SHARED BUTTONS ── */
.btn{
  padding:10px 22px;border-radius:8px;font-family:'IBM Plex Mono',monospace;
  font-size:11px;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;
  transition:all .15s;border:1px solid transparent;
}
.btn-primary{background:var(--accent);color:var(--bg);font-weight:700;}
.btn-primary:hover{opacity:.85;}
.btn-secondary{background:var(--surface2);border-color:var(--border2);color:var(--text2);}
.btn-secondary:hover{border-color:var(--text);color:var(--text);}
.btn-danger{background:var(--red-dim);border-color:var(--red);color:var(--red);}
.btn-danger:hover{background:rgba(224,90,90,.2);}

/* ── TOAST ── */
.toast{
  position:fixed;bottom:24px;right:24px;
  background:var(--surface);border:1px solid var(--border2);
  padding:12px 20px;border-radius:8px;font-size:12px;
  font-family:'IBM Plex Mono',monospace;color:var(--text);
  transform:translateY(80px);opacity:0;transition:all .3s;z-index:1000;
  display:flex;align-items:center;gap:8px;
}
.toast.show{transform:translateY(0);opacity:1;}
.toast.success .t-icon{color:var(--green);}
.toast.error .t-icon{color:var(--red);}

/* ── EMPTY ── */
.empty-state{text-align:center;padding:60px 20px;color:var(--text3);line-height:1.9;font-size:13px;}
.empty-state .ei{font-size:36px;display:block;margin-bottom:12px;}

/* ── SCROLLBAR ── */
::-webkit-scrollbar{width:5px;}
::-webkit-scrollbar-track{background:var(--bg);}
::-webkit-scrollbar-thumb{background:var(--border2);border-radius:3px;}
</style>
</head>
<body>
<div class="app">

<header>
  <div class="logo">漢字 SRS <em>// vocab desk</em></div>
  <nav>
    <button class="tab active" onclick="switchView('study')" id="tab-study">▶ Study</button>
    <button class="tab" onclick="switchView('library')" id="tab-library">Library</button>
    <button class="tab" onclick="switchView('import')" id="tab-import">Import</button>
    <button class="tab" onclick="switchView('add')" id="tab-add">+ Add Card</button>
  </nav>
</header>

<div class="body">
<aside class="sidebar">
  <div class="sidebar-section">Study</div>
  <button class="sidebar-btn active" onclick="switchView('study')" id="sb-study">
    <span class="icon">📖</span> Daily Review
  </button>
  <div class="sidebar-divider"></div>
  <div class="sidebar-section">Manage</div>
  <button class="sidebar-btn" onclick="switchView('library')" id="sb-library">
    <span class="icon">🗂</span> Library
  </button>
  <button class="sidebar-btn" onclick="switchView('add')" id="sb-add">
    <span class="icon">✏️</span> Add Single
  </button>
  <div class="sidebar-divider"></div>
  <div class="sidebar-section">Import</div>
  <button class="sidebar-btn" onclick="openImportPanel('paste')" id="sb-paste">
    <span class="icon">📋</span> Paste Table
  </button>
  <button class="sidebar-btn" onclick="openImportPanel('csv')" id="sb-csv">
    <span class="icon">📂</span> CSV / Excel
  </button>
  <div class="sidebar-divider"></div>
  <div class="sidebar-section">Export</div>
  <button class="sidebar-btn" onclick="exportCSV()">
    <span class="icon">💾</span> Export CSV
  </button>
</aside>

<div class="content">

<!-- ── STUDY ── -->
<div class="view active" id="view-study">
  <div class="stats-row">
    <div class="stat"><div class="n" id="s-due">0</div><div class="l">Due Today</div></div>
    <div class="stat"><div class="n" id="s-total">0</div><div class="l">Total</div></div>
    <div class="stat"><div class="n" id="s-streak">0</div><div class="l">Streak</div></div>
    <div class="stat"><div class="n" id="s-done">0</div><div class="l">Done Today</div></div>
  </div>
  <div class="prog-wrap"><div class="prog-bar" id="prog" style="width:0%"></div></div>

  <div id="area-card">
    <div class="study-card" id="study-card">
      <div class="card-tag" id="c-cat">—</div>
      <div class="card-pos" id="c-pos">— / —</div>
      <div class="en-prompt" id="c-en">—</div>
      <div class="reveal-hint">click answer to reveal · or press Space</div>
      <div class="answer-wrap" id="c-answer" onclick="revealAnswer()">
        <div class="zh-big" id="c-zh">???</div>
        <div class="pinyin-line" id="c-py">???</div>
      </div>
    </div>
    <div style="display:flex;justify-content:center;margin-bottom:16px;">
      <button class="reveal-cta" id="reveal-btn" onclick="revealAnswer()">
        <span>Reveal Answer</span><span style="font-size:14px;">↵</span>
      </button>
    </div>
  </div>

  <div class="rating-grid" id="area-rating" style="display:none">
    <button class="r-btn q0" onclick="rate(0)"><span class="rn">0</span><span class="rl">Blackout</span></button>
    <button class="r-btn q1" onclick="rate(1)"><span class="rn">1</span><span class="rl">Hard</span></button>
    <button class="r-btn q2" onclick="rate(2)"><span class="rn">2</span><span class="rl">Good</span></button>
    <button class="r-btn q3" onclick="rate(3)"><span class="rn">3</span><span class="rl">Easy</span></button>
  </div>

  <div id="area-sentence" style="display:none;margin-top:12px;">
    <div class="sentence-card">
      <div class="sentence-zh" id="c-sent-zh">—</div>
      <div class="sentence-en" id="c-sent-en">—</div>
    </div>
  </div>

  <div id="area-complete" style="display:none;margin-top:8px;">
    <div class="complete-box">
      <div class="big">✅</div>
      <h2>Session Complete</h2>
      <p>All cards reviewed. Your schedule is set — come back tomorrow to keep the streak alive.</p>
      <button class="btn btn-secondary" onclick="restartSession()" style="margin-top:8px;">Review Again</button>
    </div>
  </div>

  <div id="area-empty" style="display:none;margin-top:8px;">
    <div class="empty-state">
      <span class="ei">📭</span>
      No cards yet. Use <strong>Import</strong> or <strong>Add Card</strong> to get started.
    </div>
  </div>
</div>

<!-- ── LIBRARY ── -->
<div class="view" id="view-library">
  <div class="lib-toolbar">
    <input class="lib-search" type="text" placeholder="Search cards…" oninput="renderLibrary()" id="lib-search">
    <select class="cat-filter" onchange="renderLibrary()" id="cat-filter">
      <option value="">All Categories</option>
      <option>PCB Design</option>
      <option>Product Development</option>
      <option>Supply Chain</option>
      <option>General</option>
    </select>
    <button class="btn btn-danger" onclick="confirmClearAll()" style="white-space:nowrap;font-size:10px;">Clear All</button>
  </div>
  <table class="lib-table">
    <thead>
      <tr>
        <th>Chinese</th>
        <th>English</th>
        <th>Category</th>
        <th>Next Review</th>
        <th></th>
      </tr>
    </thead>
    <tbody id="lib-body"></tbody>
  </table>
  <div id="lib-empty" class="empty-state" style="display:none">
    <span class="ei">📚</span>No cards match your search.
  </div>
</div>

<!-- ── IMPORT ── -->
<div class="view" id="view-import">
  <div class="import-grid" id="import-cards">
    <div class="import-card" onclick="openImportPanel('paste')">
      <div class="ic-icon">📋</div>
      <h3>Paste from Chat</h3>
      <p>Copy a vocab table directly from a Claude conversation and paste it here. Supports the Markdown table format used in our sessions.</p>
    </div>
    <div class="import-card" onclick="openImportPanel('csv')">
      <div class="ic-icon">📂</div>
      <h3>Upload CSV / Excel</h3>
