<script>
// ════════════════════════════════════════════
//  DATA / STORAGE
// ════════════════════════════════════════════
const KEY = 'hanzi_srs_v2';
let db = {cards:[], streak:0, lastStudied:null, doneToday:0};
let session = {queue:[], index:0, revealed:false};
let pastePreviewCards = [];
let csvPreviewCards = [];
let bulkPreviewCards = [];

function load(){
  try{ const r=localStorage.getItem(KEY); if(r) db=JSON.parse(r); }catch(e){}
  const today = new Date().toDateString();
  const yesterday = new Date(Date.now()-86400000).toDateString();
  if(db.lastStudied !== today){
    if(db.lastStudied === yesterday) db.streak = (db.streak||0)+1;
    else if(db.lastStudied && db.lastStudied !== today) db.streak = 0;
    db.doneToday = 0;
  }
}
function save(){ localStorage.setItem(KEY,JSON.stringify(db)); }

// ════════════════════════════════════════════
//  SM-2
// ════════════════════════════════════════════
function sm2(card, q){
  let {interval,easeFactor,repetitions} = card;
  if(q<1){ repetitions=0; interval=1; }
  else{
    if(repetitions===0) interval=1;
    else if(repetitions===1) interval=3;
    else interval=Math.round(interval*easeFactor);
    repetitions++;
    easeFactor = Math.max(1.3, easeFactor+(0.1-(3-q)*(0.08+(3-q)*0.02)));
  }
  return {...card, interval, easeFactor, repetitions, nextReview:Date.now()+interval*86400000};
}
function isDue(c){ return Date.now()>=c.nextReview; }
function makeCard(data){
  return {
    id: Date.now()+Math.random(),
    chinese: data.chinese||'', pinyin: data.pinyin||'',
    english: data.english||'', category: data.category||'General',
    sentenceZh: data.sentenceZh||'', sentenceEn: data.sentenceEn||'',
    interval:1, easeFactor:2.5, repetitions:0, nextReview:Date.now()
  };
}

// ════════════════════════════════════════════
//  SEED
// ════════════════════════════════════════════
const SEED=[
  {chinese:'供應鏈',pinyin:'Gōngyìng liàn',english:'Supply chain',category:'Supply Chain',sentenceZh:'我們的供應鏈受到了影響。',sentenceEn:'Our supply chain has been impacted.'},
  {chinese:'報價',pinyin:'Bàojià',english:'Quotation / Quote',category:'Supply Chain',sentenceZh:'請盡快提供報價。',sentenceEn:'Please provide a quote as soon as possible.'},
  {chinese:'交期',pinyin:'Jiāoqī',english:'Lead time',category:'Supply Chain',sentenceZh:'這個零件的交期是幾週？',sentenceEn:'What is the lead time for this component?'},
  {chinese:'印刷電路板',pinyin:'Yìnshuā diànlùbǎn',english:'PCB (Printed Circuit Board)',category:'PCB Design',sentenceZh:'這塊印刷電路板需要重新設計。',sentenceEn:'This PCB needs to be redesigned.'},
  {chinese:'走線',pinyin:'Zǒuxiàn',english:'Trace / Track',category:'PCB Design',sentenceZh:'走線的寬度需要調整。',sentenceEn:'The trace width needs to be adjusted.'},
  {chinese:'封裝',pinyin:'Fēngzhuāng',english:'Footprint',category:'PCB Design',sentenceZh:'請確認封裝是否正確。',sentenceEn:'Please verify the footprint is correct.'},
  {chinese:'量產',pinyin:'Liàngchǎn',english:'Mass production',category:'Product Development',sentenceZh:'我們計劃下季度開始量產。',sentenceEn:'We plan to begin mass production next quarter.'},
  {chinese:'原型',pinyin:'Yuánxíng',english:'Prototype',category:'Product Development',sentenceZh:'第一個原型已經完成了。',sentenceEn:'The first prototype is complete.'},
  {chinese:'物料清單',pinyin:'Wùliào qīngdān',english:'Bill of Materials (BOM)',category:'PCB Design',sentenceZh:'請更新物料清單。',sentenceEn:'Please update the BOM.'},
  {chinese:'採購單',pinyin:'Cǎigòu dān',english:'Purchase order (PO)',category:'Supply Chain',sentenceZh:'採購單已經發出了。',sentenceEn:'The purchase order has been sent.'},
  {chinese:'里程碑',pinyin:'Lǐchéngbēi',english:'Milestone',category:'Product Development',sentenceZh:'我們已經達到了第一個里程碑。',sentenceEn:'We have reached the first milestone.'},
  {chinese:'韌體',pinyin:'Rèntǐ',english:'Firmware',category:'PCB Design',sentenceZh:'韌體更新需要測試。',sentenceEn:'The firmware update needs to be tested.'},
  {chinese:'廠商',pinyin:'Chǎngshāng',english:'Vendor',category:'Supply Chain',sentenceZh:'我需要聯繫廠商確認規格。',sentenceEn:'I need to contact the vendor to confirm specs.'},
  {chinese:'檢驗',pinyin:'Jiǎnyàn',english:'Inspection',category:'Supply Chain',sentenceZh:'貨物到達後需要進行檢驗。',sentenceEn:'An inspection is required upon arrival of goods.'},
  {chinese:'設計審查',pinyin:'Shèjì shěnchá',english:'Design review',category:'Product Development',sentenceZh:'設計審查排在下週四。',sentenceEn:'The design review is scheduled for next Thursday.'},
];
function seedIfEmpty(){ if(!db.cards.length){ db.cards=SEED.map(makeCard); save(); } }

// ════════════════════════════════════════════
//  STUDY
// ════════════════════════════════════════════
function buildQueue(){ session.queue=db.cards.filter(isDue); session.index=0; session.revealed=false; }
function currentCard(){ return session.queue[session.index]||null; }

function revealAnswer(){
  if(session.revealed) return;
  session.revealed=true;
  document.getElementById('c-answer').classList.add('revealed');
  document.getElementById('reveal-btn').style.display='none';
  document.getElementById('area-rating').style.display='grid';
  const c=currentCard();
  if(c&&c.sentenceZh){
    document.getElementById('c-sent-zh').textContent=c.sentenceZh;
    document.getElementById('c-sent-en').textContent=c.sentenceEn||'';
    document.getElementById('area-sentence').style.display='block';
  }
}

function rate(q){
  const c=currentCard(); if(!c) return;
  const updated=sm2(c,q);
  const i=db.cards.findIndex(x=>x.id===c.id);
  if(i!==-1) db.cards[i]=updated;
  db.doneToday=(db.doneToday||0)+1;
  db.lastStudied=new Date().toDateString();
  save(); session.index++; session.revealed=false; renderStudy();
}

function restartSession(){ buildQueue(); renderStudy(); }

function renderStudy(){
  const c=currentCard(), total=session.queue.length, done=session.index;
  document.getElementById('s-due').textContent=db.cards.filter(isDue).length;
  document.getElementById('s-total').textContent=db.cards.length;
  document.getElementById('s-streak').textContent=db.streak||0;
  document.getElementById('s-done').textContent=db.doneToday||0;
  document.getElementById('prog').style.width=(total>0?Math.round(done/total*100):0)+'%';

  ['area-card','area-rating','area-sentence','area-complete','area-empty'].forEach(id=>
    document.getElementById(id).style.display='none'
  );
  if(!db.cards.length){ document.getElementById('area-empty').style.display='block'; return; }
  if(!c){ document.getElementById('area-complete').style.display='block'; return; }
  document.getElementById('area-card').style.display='block';
  document.getElementById('c-cat').textContent=c.category;
  document.getElementById('c-pos').textContent=`${done+1} / ${total}`;
  document.getElementById('c-en').textContent=c.english;
  document.getElementById('c-zh').textContent=c.chinese;
  document.getElementById('c-py').textContent=c.pinyin;
  document.getElementById('c-answer').classList.remove('revealed');
  document.getElementById('reveal-btn').style.display='flex';
}

// ════════════════════════════════════════════
//  LIBRARY
// ════════════════════════════════════════════
function renderLibrary(){
  const q=(document.getElementById('lib-search').value||'').toLowerCase();
  const cat=document.getElementById('cat-filter').value;
  let cards=db.cards.filter(c=>{
    const matchQ=!q||(c.chinese+c.pinyin+c.english).toLowerCase().includes(q);
    const matchC=!cat||c.category===cat;
    return matchQ&&matchC;
  });
  const tbody=document.getElementById('lib-body'); tbody.innerHTML='';
  document.getElementById('lib-empty').style.display=cards.length?'none':'block';
  cards.forEach(c=>{
    const daysUntil=Math.max(0,Math.round((c.nextReview-Date.now())/86400000));
    const dueLabel=isDue(c)?'<span class="due-now">● due now</span>'
      :daysUntil<=2?`<span class="due-soon">in ${daysUntil}d</span>`
      :`<span class="due-ok">in ${daysUntil}d</span>`;
    const tr=document.createElement('tr');
    tr.innerHTML=`
      <td><div class="td-zh">${c.chinese}</div><div class="td-py">${c.pinyin}</div></td>
      <td>${c.english}</td>
      <td><span class="td-cat">${c.category}</span></td>
      <td class="td-due">${dueLabel}</td>
      <td><button class="row-del" onclick="deleteCard('${c.id}')">✕</button></td>
    `;
    tbody.appendChild(tr);
  });
}

function deleteCard(id){
  db.cards=db.cards.filter(c=>String(c.id)!==String(id));
  save(); buildQueue(); renderLibrary(); renderStudy();
  toast('Card deleted','success');
}

function confirmClearAll(){
  if(confirm('Delete ALL cards? This cannot be undone.')){ db.cards=[]; save(); buildQueue(); renderLibrary(); renderStudy(); toast('All cards cleared','success'); }
}

// ════════════════════════════════════════════
//  IMPORT — PASTE (Markdown table)
// ════════════════════════════════════════════
function parsePastePreview(){
  const raw=document.getElementById('paste-input').value;
  pastePreviewCards=parseMarkdownTable(raw);
  renderPreview('paste-preview',pastePreviewCards);
  document.getElementById('paste-count').textContent=pastePreviewCards.length?`${pastePreviewCards.length} cards ready`:'';
  document.getElementById('paste-import-btn').disabled=!pastePreviewCards.length;
}

function parseMarkdownTable(raw){
  const lines=raw.trim().split('\n').map(l=>l.trim()).filter(l=>l.startsWith('|'));
  if(lines.length<2) return[];
  // Parse headers
  const headers=lines[0].split('|').map(h=>h.trim().toLowerCase()).filter(Boolean);
  const headerMap={};
  headers.forEach((h,i)=>{
    if(/chinese|繁體|中文|漢字/.test(h)) headerMap.chinese=i;
    if(/pinyin|拼音/.test(h)) headerMap.pinyin=i;
    if(/english|英文|en/.test(h)) headerMap.english=i;
    if(/category|cat|類別/.test(h)) headerMap.category=i;
    if(/sentence.*zh|example.*zh|sentencezh/.test(h)) headerMap.sentenceZh=i;
    if(/sentence.*en|example.*en|sentenceen/.test(h)) headerMap.sentenceEn=i;
    if(/notes?|備注/.test(h)) headerMap.notes=i;
  });
  // If no explicit english/chinese found, try column positions from common format
  // Format: | English | 繁體中文 | Pinyin | Notes |
  if(headerMap.english===undefined) headerMap.english=0;
  if(headerMap.chinese===undefined) headerMap.chinese=1;
  if(headerMap.pinyin===undefined) headerMap.pinyin=2;

  const cards=[];
  for(let i=2;i<lines.length;i++){
    const cols=lines[i].split('|').map(c=>c.trim()).filter((_,j)=>j>0);
    if(!cols.length||cols.join('').replace(/-/g,'').trim()==='') continue;
    const get=(k)=>cols[headerMap[k]]||'';
    const chinese=get('chinese'), english=get('english');
    if(!chinese&&!english) continue;
    cards.push({
      chinese: chinese||'',
      pinyin: get('pinyin'),
      english: english||'',
      category: guessCategory(get('category')||get('notes')||english),
      sentenceZh: get('sentenceZh'),
      sentenceEn: get('sentenceEn'),
    });
  }
  return cards;
}

function guessCategory(hint){
  const h=(hint||'').toLowerCase();
  if(/pcb|circuit|schematic|layout|gerber|bom|trace|via|footprint|firmware/.test(h)) return 'PCB Design';
  if(/supply|vendor|supplier|sourcing|logistics|purchase|po|lead|invoice|customs|qc|delivery/.test(h)) return 'Supply Chain';
  if(/product|npi|prototype|production|milestone|tooling|spec|revision/.test(h)) return 'Product Development';
  return 'General';
}

function importFromPaste(){
  addCards(pastePreviewCards);
  document.getElementById('paste-input').value='';
  document.getElementById('paste-preview').innerHTML='';
  document.getElementById('paste-count').textContent='';
  document.getElementById('paste-import-btn').disabled=true;
  pastePreviewCards=[];
}

// ════════════════════════════════════════════
//  IMPORT — CSV
// ════════════════════════════════════════════
function handleCSVFile(e){
  const file=e.target.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=ev=>{ csvPreviewCards=parseCSV(ev.target.result); renderPreview('csv-preview',csvPreviewCards); document.getElementById('csv-count').textContent=csvPreviewCards.length?`${csvPreviewCards.length} cards ready`:''; document.getElementById('csv-import-btn').disabled=!csvPreviewCards.length; };
  reader.readAsText(file);
}

function parseCSV(text){
  const lines=text.trim().split('\n');
  if(!lines.length) return[];
  const headers=lines[0].split(',').map(h=>h.replace(/"/g,'').trim().toLowerCase());
  const map={};
  headers.forEach((h,i)=>{
    if(/chinese|繁體|zh/.test(h)) map.chinese=i;
    if(/pinyin/.test(h)) map.pinyin=i;
    if(/english|en$/.test(h)) map.english=i;
    if(/cat/.test(h)) map.category=i;
    if(/sentencezh|sentence_zh/.test(h)) map.sentenceZh=i;
    if(/sentenceen|sentence_en/.test(h)) map.sentenceEn=i;
  });
  if(map.chinese===undefined) map.chinese=0;
  if(map.english===undefined) map.english=2;
  const cards=[];
  for(let i=1;i<lines.length;i++){
    const cols=parseCSVLine(lines[i]);
    const get=k=>map[k]!==undefined?(cols[map[k]]||'').replace(/^"|"$/g,'').trim():'';
    if(!get('chinese')&&!get('english')) continue;
    cards.push({ chinese:get('chinese'), pinyin:get('pinyin'), english:get('english'), category:get('category')||guessCategory(get('english')), sentenceZh:get('sentenceZh'), sentenceEn:get('sentenceEn') });
  }
  return cards;
}

function parseCSVLine(line){
  const result=[]; let cur='', inQ=false;
  for(let i=0;i<line.length;i++){
    if(line[i]==='"') inQ=!inQ;
    else if(line[i]===','&&!inQ){ result.push(cur); cur=''; }
    else cur+=line[i];
  }
  result.push(cur); return result;
}

function downloadTemplate(){
  const header='Chinese,Pinyin,English,Category,SentenceZh,SentenceEn\n';
  const sample='供應鏈,Gōngyìng liàn,Supply chain,Supply Chain,我們的供應鏈受到了影響。,Our supply chain has been impacted.\n';
  const blob=new Blob([header+sample],{type:'text/csv'});
  const a=document.createElement('a'); a.href=URL.createObjectURL(blob); a.download='hanzi-srs-template.csv'; a.click();
}

function importFromCSV(){
  addCards(csvPreviewCards);
  csvPreviewCards=[]; document.getElementById('csv-preview').innerHTML='';
  document.getElementById('csv-count').textContent=''; document.getElementById('csv-import-btn').disabled=true;
  document.getElementById('csv-file-input').value='';
}

// ════════════════════════════════════════════
//  IMPORT — BULK TEXT
// ════════════════════════════════════════════
function parseBulkPreview(){
  const raw=document.getElementById('bulk-input').value;
  bulkPreviewCards=parseBulkText(raw);
  renderPreview('bulk-preview',bulkPreviewCards);
  document.getElementById('bulk-count').textContent=bulkPreviewCards.length?`${bulkPreviewCards.length} cards ready`:'';
  document.getElementById('bulk-import-btn').disabled=!bulkPreviewCards.length;
}

function parseBulkText(raw){
  return raw.trim().split('\n').map(line=>{
    const parts=line.split('|').map(p=>p.trim());
    if(parts.length<3) return null;
    return { chinese:parts[0], pinyin:parts[1], english:parts[2], category:parts[3]||guessCategory(parts[2]), sentenceZh:'', sentenceEn:'' };
  }).filter(Boolean);
}

function importFromBulk(){
  addCards(bulkPreviewCards);
  document.getElementById('bulk-input').value=''; document.getElementById('bulk-preview').innerHTML='';
  document.getElementById('bulk-count').textContent=''; document.getElementById('bulk-import-btn').disabled=true;
  bulkPreviewCards=[];
}

// ════════════════════════════════════════════
//  SHARED IMPORT HELPERS
// ════════════════════════════════════════════
function addCards(cards){
  if(!cards.length) return;
  // Deduplicate by chinese
  const existing=new Set(db.cards.map(c=>c.chinese));
  const newCards=cards.filter(c=>!existing.has(c.chinese));
  const skipped=cards.length-newCards.length;
  newCards.forEach(c=>db.cards.push(makeCard(c)));
  save(); buildQueue(); renderStudy();
  const msg=`${newCards.length} card${newCards.length!==1?'s':''} imported`+(skipped?` (${skipped} duplicate${skipped!==1?'s':''} skipped)`:'');
  toast(msg,'success');
  closeImportPanel();
  switchView('library');
}

function renderPreview(containerId, cards){
  const el=document.getElementById(containerId);
  if(!cards.length){ el.innerHTML=''; return; }
  el.innerHTML=`
    <div class="preview-table-wrap">
      <table class="preview-table">
        <thead><tr><th>Chinese</th><th>Pinyin</th><th>English</th><th>Category</th><th></th></tr></thead>
        <tbody>${cards.map(c=>`
          <tr>
            <td class="pv-zh">${c.chinese||'<span style="color:var(--red)">missing</span>'}</td>
            <td style="font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--accent)">${c.pinyin||''}</td>
            <td>${c.english||'<span style="color:var(--red)">missing</span>'}</td>
            <td style="font-size:10px;color:var(--green)">${c.category}</td>
            <td>${c.chinese&&c.english?'<span class="pv-check">✓</span>':'<span class="pv-warn">⚠</span>'}</td>
          </tr>`).join('')}
        </tbody>
      </table>
    </div>`;
}

// ════════════════════════════════════════════
//  EXPORT
// ════════════════════════════════════════════
function exportCSV(){
  const header='Chinese,Pinyin,English,Category,SentenceZh,SentenceEn,Interval,EaseFactor,Repetitions\n';
  const rows=db.cards.map(c=>[c.chinese,c.pinyin,c.english,c.category,c.sentenceZh||'',c.sentenceEn||'',c.interval||1,c.easeFactor||2.5,c.repetitions||0].map(v=>`"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
  const blob=new Blob([header+rows],{type:'text/csv'});
  const a=document.createElement('a'); a.href=URL.createObjectURL(blob);
  a.download=`hanzi-srs-export-${new Date().toISOString().slice(0,10)}.csv`; a.click();
  toast('Exported to CSV','success');
}

// ════════════════════════════════════════════
//  ADD SINGLE
// ════════════════════════════════════════════
function saveNewCard(){
  const zh=document.getElementById('a-zh').value.trim();
  const en=document.getElementById('a-en').value.trim();
  if(!zh||!en){ toast('Chinese and English are required','error'); return; }
  db.cards.push(makeCard({
    chinese:zh, pinyin:document.getElementById('a-py').value.trim(),
    english:en, category:document.getElementById('a-cat').value,
    sentenceZh:document.getElementById('a-szh').value.trim(),
    sentenceEn:document.getElementById('a-sen').value.trim(),
  }));
  save(); buildQueue(); renderStudy();
  toast(`"${zh}" added`,'success');
  clearAddForm();
}
function clearAddForm(){ ['a-zh','a-py','a-en','a-szh','a-sen'].forEach(id=>document.getElementById(id).value=''); }

// ════════════════════════════════════════════
//  NAVIGATION
// ════════════════════════════════════════════
const VIEWS=['study','library','import','add'];
function switchView(v){
  VIEWS.forEach(id=>{
    document.getElementById('view-'+id).classList.toggle('active',id===v);
    const t=document.getElementById('tab-'+id); if(t) t.classList.toggle('active',id===v);
    const s=document.getElementById('sb-'+id); if(s) s.classList.toggle('active',id===v);
  });
  if(v==='library') renderLibrary();
  if(v==='import') closeImportPanel();
}

// ════════════════════════════════════════════
//  IMPORT PANELS
// ════════════════════════════════════════════
function openImportPanel(name){
  switchView('import');
  document.getElementById('import-cards').style.display='none';
  ['paste','csv','bulk'].forEach(p=>document.getElementById('panel-'+p).classList.remove('open'));
  document.getElementById('panel-'+name).classList.add('open');
}
function closeImportPanel(){
  document.getElementById('import-cards').style.display='grid';
  ['paste','csv','bulk'].forEach(p=>document.getElementById('panel-'+p).classList.remove('open'));
}

// Drag and drop for CSV
const dropZone=document.getElementById('file-drop');
dropZone.addEventListener('dragover',e=>{e.preventDefault();dropZone.classList.add('dragover');});
dropZone.addEventListener('dragleave',()=>dropZone.classList.remove('dragover'));
dropZone.addEventListener('drop',e=>{
  e.preventDefault(); dropZone.classList.remove('dragover');
  const file=e.dataTransfer.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=ev=>{ csvPreviewCards=parseCSV(ev.target.result); renderPreview('csv-preview',csvPreviewCards); document.getElementById('csv-count').textContent=csvPreviewCards.length?`${csvPreviewCards.length} cards ready`:''; document.getElementById('csv-import-btn').disabled=!csvPreviewCards.length; };
  reader.readAsText(file);
});

// ════════════════════════════════════════════
//  TOAST
// ════════════════════════════════════════════
let toastTimer;
function toast(msg,type='success'){
  const el=document.getElementById('toast');
  document.getElementById('toast-msg').textContent=msg;
  el.className=`toast ${type} show`;
  clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>el.classList.remove('show'),3000);
}

// ════════════════════════════════════════════
//  KEYBOARD
// ════════════════════════════════════════════
document.addEventListener('keydown',e=>{
  if(document.getElementById('view-study').classList.contains('active')){
    if(!session.revealed&&(e.key===' '||e.key==='Enter')){ e.preventDefault(); revealAnswer(); }
    if(session.revealed){
      if(e.key==='1') rate(0); if(e.key==='2') rate(1);
      if(e.key==='3') rate(2); if(e.key==='4') rate(3);
    }
  }
});

// ════════════════════════════════════════════
//  INIT
// ════════════════════════════════════════════
load(); seedIfEmpty(); buildQueue(); renderStudy();
</script>
