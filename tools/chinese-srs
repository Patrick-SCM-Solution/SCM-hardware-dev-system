}

// ════════════════════════════════════════════
//  IMPORT — PASTE
// ════════════════════════════════════════════
function parsePastePreview() {
  pastePreviewCards = parseMarkdownTable(document.getElementById('paste-input').value);
  renderPreview('paste-preview', pastePreviewCards);
  const n = pastePreviewCards.length;
  document.getElementById('paste-count').textContent = n ? `${n} cards ready` : '';
  document.getElementById('paste-import-btn').disabled = !n;
}

function parseMarkdownTable(raw) {
  const lines = raw.trim().split('\n')
    .map(l => l.trim()).filter(l => l.startsWith('|'));
  if (lines.length < 2) return [];

  const headers = lines[0].split('|')
    .map(h => h.trim().toLowerCase()).filter(Boolean);
  const hm = {};
  headers.forEach((h, i) => {
    if (/chinese|繁體|中文|漢字/.test(h)) hm.chinese = i;
    if (/pinyin|拼音/.test(h))            hm.pinyin  = i;
    if (/english|英文|en/.test(h))        hm.english  = i;
    if (/category|cat|類別/.test(h))      hm.category = i;
    if (/sentence.*zh|sentencezh/.test(h)) hm.sentenceZh = i;
    if (/sentence.*en|sentenceen/.test(h)) hm.sentenceEn = i;
    if (/notes?|備注/.test(h))            hm.notes = i;
  });
  if (hm.english  === undefined) hm.english  = 0;
  if (hm.chinese  === undefined) hm.chinese  = 1;
  if (hm.pinyin   === undefined) hm.pinyin   = 2;

  const cards = [];
  for (let i = 2; i < lines.length; i++) {
    const cols = lines[i].split('|')
      .map(c => c.trim()).filter((_, j) => j > 0);
    if (!cols.length || cols.join('').replace(/-/g,'').trim() === '') continue;
    const get = k => cols[hm[k]] || '';
    const chinese = get('chinese');
    const english = get('english');
    if (!chinese && !english) continue;
    cards.push({
      chinese,
      pinyin:     get('pinyin'),
      english,
      category:   guessCategory(get('category') || get('notes') || english),
      sentenceZh: get('sentenceZh'),
      sentenceEn: get('sentenceEn'),
    });
  }
  return cards;
}

function guessCategory(hint) {
  const h = (hint || '').toLowerCase();
  if (/pcb|circuit|schematic|layout|gerber|bom|trace|via|footprint|firmware/.test(h))
    return 'PCB Design';
  if (/supply|vendor|supplier|sourcing|logistics|purchase|po|lead|invoice|customs|qc/.test(h))
    return 'Supply Chain';
  if (/product|npi|prototype|production|milestone|tooling|spec|revision/.test(h))
    return 'Product Development';
  return 'General';
}

function importFromPaste() {
  addCards(pastePreviewCards);
  document.getElementById('paste-input').value = '';
  document.getElementById('paste-preview').innerHTML = '';
  document.getElementById('paste-count').textContent = '';
  document.getElementById('paste-import-btn').disabled = true;
  pastePreviewCards = [];
}

// ════════════════════════════════════════════
//  IMPORT — CSV
// ════════════════════════════════════════════
function handleCSVFile(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    csvPreviewCards = parseCSV(ev.target.result);
    renderPreview('csv-preview', csvPreviewCards);
    const n = csvPreviewCards.length;
    document.getElementById('csv-count').textContent = n ? `${n} cards ready` : '';
    document.getElementById('csv-import-btn').disabled = !n;
  };
  reader.readAsText(file);
}

function parseCSV(text) {
  const lines = text.trim().split('\n');
  if (!lines.length) return [];
  const headers = lines[0].split(',')
    .map(h => h.replace(/"/g,'').trim().toLowerCase());
  const map = {};
  headers.forEach((h, i) => {
    if (/chinese|繁體|zh/.test(h)) map.chinese = i;
    if (/pinyin/.test(h))          map.pinyin  = i;
    if (/english|en$/.test(h))     map.english  = i;
    if (/cat/.test(h))             map.category = i;
    if (/sentencezh|sentence_zh/.test(h)) map.sentenceZh = i;
    if (/sentenceen|sentence_en/.test(h)) map.sentenceEn = i;
  });
  if (map.chinese === undefined) map.chinese = 0;
  if (map.english === undefined) map.english = 2;

  const cards = [];
  for (let i = 1; i < lines.length; i++) {
    const cols = parseCSVLine(lines[i]);
    const get = k =>
      map[k] !== undefined
        ? (cols[map[k]] || '').replace(/^"|"$/g,'').trim()
        : '';
    if (!get('chinese') && !get('english')) continue;
    cards.push({
      chinese:    get('chinese'),
      pinyin:     get('pinyin'),
      english:    get('english'),
      category:   get('category') || guessCategory(get('english')),
      sentenceZh: get('sentenceZh'),
      sentenceEn: get('sentenceEn'),
    });
  }
  return cards;
}

function parseCSVLine(line) {
  const result = [];
  let cur = '', inQ = false;
  for (let i = 0; i < line.length; i++) {
    if (line[i] === '"') inQ = !inQ;
    else if (line[i] === ',' && !inQ) { result.push(cur); cur = ''; }
    else cur += line[i];
  }
  result.push(cur);
  return result;
}

function downloadTemplate() {
  const header = 'Chinese,Pinyin,English,Category,SentenceZh,SentenceEn\n';
  const sample = '供應鏈,Gōngyìng liàn,Supply chain,Supply Chain,' +
    '我們的供應鏈受到了影響。,Our supply chain has been impacted.\n';
  const blob = new Blob([header + sample], { type: 'text/csv' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'hanzi-srs-template.csv';
  a.click();
}

function importFromCSV() {
  addCards(csvPreviewCards);
  csvPreviewCards = [];
  document.getElementById('csv-preview').innerHTML = '';
  document.getElementById('csv-count').textContent = '';
  document.getElementById('csv-import-btn').disabled = true;
  document.getElementById('csv-file-input').value = '';
}

// ════════════════════════════════════════════
//  IMPORT — BULK
// ════════════════════════════════════════════
function parseBulkPreview() {
  bulkPreviewCards = parseBulkText(document.getElementById('bulk-input').value);
  renderPreview('bulk-preview', bulkPreviewCards);
  const n = bulkPreviewCards.length;
  document.getElementById('bulk-count').textContent = n ? `${n} cards ready` : '';
  document.getElementById('bulk-import-btn').disabled = !n;
}

function parseBulkText(raw) {
  return raw.trim().split('\n').map(line => {
    const parts = line.split('|').map(p => p.trim());
    if (parts.length < 3) return null;
    return {
      chinese:    parts[0],
      pinyin:     parts[1],
      english:    parts[2],
      category:   parts[3] || guessCategory(parts[2]),
      sentenceZh: '',
      sentenceEn: '',
    };
  }).filter(Boolean);
}

function importFromBulk() {
  addCards(bulkPreviewCards);
  document.getElementById('bulk-input').value = '';
  document.getElementById('bulk-preview').innerHTML = '';
  document.getElementById('bulk-count').textContent = '';
  document.getElementById('bulk-import-btn').disabled = true;
  bulkPreviewCards = [];
}

// ════════════════════════════════════════════
//  SHARED IMPORT HELPERS
// ════════════════════════════════════════════
function addCards(cards) {
  if (!cards.length) return;
  const existing = new Set(db.cards.map(c => c.chinese));
  const newCards = cards.filter(c => !existing.has(c.chinese));
  const skipped = cards.length - newCards.length;
  newCards.forEach(c => db.cards.push(makeCard(c)));
  save(); buildQueue(); renderStudy();
  const msg = `${newCards.length} card${newCards.length !== 1 ? 's' : ''} imported` +
    (skipped ? ` (${skipped} duplicate${skipped !== 1 ? 's' : ''} skipped)` : '');
  toast(msg, 'success');
  closeImportPanel();
  switchView('library');
}

function renderPreview(containerId, cards) {
  const el = document.getElementById(containerId);
  if (!cards.length) { el.innerHTML = ''; return; }
  el.innerHTML = `
    <div class="preview-table-wrap">
      <table class="preview-table">
        <thead>
          <tr>
            <th>Chinese</th><th>Pinyin</th>
            <th>English</th><th>Category</th><th></th>
          </tr>
        </thead>
        <tbody>
          ${cards.map(c => `
            <tr>
              <td class="pv-zh">
                ${c.chinese || '<span style="color:var(--scm-warn)">missing</span>'}
              </td>
              <td style="font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--scm-amber)">
                ${c.pinyin || ''}
              </td>
              <td>
                ${c.english || '<span style="color:var(--scm-warn)">missing</span>'}
              </td>
              <td style="font-size:10px;color:var(--scm-teal)">${c.category}</td>
              <td>
                ${c.chinese && c.english
                  ? '<span class="pv-check">✓</span>'
                  : '<span class="pv-warn">⚠</span>'}
              </td>
            </tr>`).join('')}
        </tbody>
      </table>
    </div>`;
}

// ════════════════════════════════════════════
//  EXPORT
// ════════════════════════════════════════════
function exportCSV() {
  const header =
    'Chinese,Pinyin,English,Category,SentenceZh,SentenceEn,' +
    'Interval,EaseFactor,Repetitions\n';
  const rows = db.cards.map(c => {
    const fields = [
      c.chinese, c.pinyin, c.english, c.category,
      c.sentenceZh || '', c.sentenceEn || '',
      c.interval || 1, c.easeFactor || 2.5, c.repetitions || 0
    ];
    return fields.map(v => `"${String(v).replace(/"/g,'""')}"`).join(',');
  }).join('\n');
  const blob = new Blob([header + rows], { type: 'text/csv' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `hanzi-srs-export-${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
  toast('Exported to CSV', 'success');
}

// ════════════════════════════════════════════
//  ADD SINGLE
// ════════════════════════════════════════════
function saveNewCard() {
  const zh = document.getElementById('a-zh').value.trim();
  const en = document.getElementById('a-en').value.trim();
  if (!zh || !en) { toast('Chinese and English are required', 'error'); return; }
  db.cards.push(makeCard({
    chinese:    zh,
    pinyin:     document.getElementById('a-py').value.trim(),
    english:    en,
    category:   document.getElementById('a-cat').value,
    sentenceZh: document.getElementById('a-szh').value.trim(),
    sentenceEn: document.getElementById('a-sen').value.trim(),
  }));
  save(); buildQueue(); renderStudy();
  toast(`"${zh}" added`, 'success');
  clearAddForm();
}
function clearAddForm() {
  ['a-zh','a-py','a-en','a-szh','a-sen']
    .forEach(id => document.getElementById(id).value = '');
}

// ════════════════════════════════════════════
//  NAVIGATION
// ════════════════════════════════════════════
const VIEWS = ['study','library','import','add'];
function switchView(v) {
  VIEWS.forEach(id => {
    document.getElementById('view-' + id).classList.toggle('active', id === v);
    const t = document.getElementById('tab-' + id);
    if (t) t.classList.toggle('active', id === v);
    const s = document.getElementById('sb-' + id);
    if (s) s.classList.toggle('active', id === v);
  });
  if (v === 'library') renderLibrary();
  if (v === 'import') closeImportPanel();
}

// ════════════════════════════════════════════
//  IMPORT PANELS
// ════════════════════════════════════════════
function openImportPanel(name) {
  switchView('import');
  document.getElementById('import-cards').style.display = 'none';
  ['paste','csv','bulk'].forEach(p =>
    document.getElementById('panel-' + p).classList.remove('open')
  );
  document.getElementById('panel-' + name).classList.add('open');
}
function closeImportPanel() {
  document.getElementById('import-cards').style.display = 'grid';
  ['paste','csv','bulk'].forEach(p =>
    document.getElementById('panel-' + p).classList.remove('open')
  );
}

// Drag and drop for CSV
const dropZone = document.getElementById('file-drop');
dropZone.addEventListener('dragover', e => {
  e.preventDefault();
  dropZone.classList.add('dragover');
});
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
dropZone.addEventListener('drop', e => {
  e.preventDefault();
  dropZone.classList.remove('dragover');
  const file = e.dataTransfer.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = ev => {
    csvPreviewCards = parseCSV(ev.target.result);
    renderPreview('csv-preview', csvPreviewCards);
    const n = csvPreviewCards.length;
    document.getElementById('csv-count').textContent = n ? `${n} cards ready` : '';
    document.getElementById('csv-import-btn').disabled = !n;
  };
  reader.readAsText(file);
});

// ════════════════════════════════════════════
//  TOAST
// ════════════════════════════════════════════
let toastTimer;
function toast(msg, type = 'success') {
  const el = document.getElementById('toast');
  document.getElementById('toast-msg').textContent = msg;
  el.className = `toast ${type} show`;
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 3000);
}

// ════════════════════════════════════════════
//  KEYBOARD
// ════════════════════════════════════════════
document.addEventListener('keydown', e => {
  if (!document.getElementById('view-study').classList.contains('active')) return;
  if (!session.revealed && (e.key === ' ' || e.key === 'Enter')) {
    e.preventDefault();
    revealAnswer();
  }
  if (session.revealed) {
    if (e.key === '1') rate(0);
    if (e.key === '2') rate(1);
    if (e.key === '3') rate(2);
    if (e.key === '4') rate(3);
  }
});

// ════════════════════════════════════════════
//  INIT
// ════════════════════════════════════════════
load(); seedIfEmpty(); buildQueue(); renderStudy();
</script>
