<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>漢字 SRS — Vocab Desk</title>

<!-- SCM System Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700
  &family=Barlow+Condensed:wght@600;700;800
  &family=IBM+Plex+Mono:ital,wght@0,400;0,600;1,400
  &family=Noto+Sans+TC:wght@400;700&display=swap" rel="stylesheet">

<!-- SCM Shared Stylesheet -->
<link rel="stylesheet" href="../css/scm-styles.css">

<style>
/* ── SRS-SPECIFIC LAYOUT & COMPONENTS ─────────────────────────
   All colors inherited exclusively from scm-styles.css tokens.
   No hardcoded color values anywhere in this block.
   ─────────────────────────────────────────────────────────── */

/* App shell */
.app {
  display: grid;
  grid-template-rows: auto 1fr;
  height: 100vh;
  overflow: hidden;
}
body { overflow: hidden; }

/* ── HEADER ── */
.srs-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28px;
  height: 52px;
  background: var(--surf);
  border-bottom: 1px solid var(--bdr);
  position: relative;
  z-index: 10;
}

.srs-logo {
  font-family: "Barlow Condensed", sans-serif;
  font-size: 14px;
  font-weight: 800;
  letter-spacing: 0.12em;
  color: var(--scm-blue);
  text-transform: uppercase;
}
.srs-logo em { color: var(--muted); font-style: normal; }

/* Header nav tabs — override SCM .tab for header context */
.srs-nav { display: flex; gap: 4px; }
.srs-tab {
  background: none;
  border: 1px solid transparent;
  color: var(--muted);
  padding: 5px 14px;
  border-radius: 4px;
  cursor: pointer;
  font-family: "Barlow Condensed", sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.08em;
  transition: all .15s;
  text-transform: uppercase;
}
.srs-tab:hover { color: var(--text); border-color: var(--bdr); }
.srs-tab.active {
  color: var(--scm-blue);
  border-color: var(--scm-blue);
  background: var(--bg-hover);
}

/* ── BODY LAYOUT ── */
.srs-body { display: flex; overflow: hidden; }

.srs-sidebar {
  width: 220px;
  flex-shrink: 0;
  border-right: 1px solid var(--bdr);
  background: var(--surf);
  padding: 20px 0;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.sidebar-section {
  padding: 16px 20px 6px;
  font-family: "Barlow Condensed", sans-serif;
  font-size: 9px;
  font-weight: 700;
  color: var(--muted);
  letter-spacing: 0.14em;
  text-transform: uppercase;
}

.sidebar-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 20px;
  color: var(--muted);
  cursor: pointer;
  font-size: 12px;
  font-family: Barlow, sans-serif;
  transition: all .15s;
  border: none;
  border-left: 2px solid transparent;
  background: none;
  width: 100%;
  text-align: left;
}
.sidebar-btn:hover { color: var(--text); background: var(--bg-hover); }
.sidebar-btn.active {
  color: var(--scm-blue);
  background: var(--bg-hover);
  border-left-color: var(--scm-blue);
}
.sidebar-btn .icon { font-size: 15px; width: 20px; text-align: center; }

.sidebar-divider { height: 1px; background: var(--bdr); margin: 10px 16px; }

.srs-content { flex: 1; overflow-y: auto; padding: 32px; }

/* ── VIEWS ── */
.view { display: none; max-width: 780px; margin: 0 auto; }
.view.active { display: block; }

/* ── STUDY CARD — Chinese-specific, no SCM equivalent ── */
.study-card {
  background: var(--surf);
  border: 1px solid var(--bdr);
  border-radius: 8px;
  padding: 52px 44px;
  min-height: 300px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18px;
  position: relative;
  transition: border-color .2s, box-shadow .2s;
  margin-bottom: 16px;
  box-shadow: var(--shadow-sm);
}
.study-card:hover { border-color: var(--scm-blue); box-shadow: var(--shadow-md); }

.card-tag {
  position: absolute;
  top: 16px;
  left: 16px;
  font-family: "Barlow Condensed", sans-serif;
  font-size: 9px;
  font-weight: 700;
  color: var(--scm-green);
  border: 1px solid var(--scm-green);
  border-radius: 3px;
  padding: 2px 8px;
  letter-spacing: .1em;
  text-transform: uppercase;
}

.card-pos {
  position: absolute;
  top: 16px;
  right: 16px;
  font-family: "Barlow Condensed", sans-serif;
  font-size: 11px;
  font-weight: 700;
  color: var(--muted);
  letter-spacing: .06em;
}

.en-prompt {
  font-family: "Barlow Condensed", sans-serif;
  font-size: 28px;
  font-weight: 800;
  color: var(--text);
  text-align: center;
  letter-spacing: .03em;
  text-transform: uppercase;
}

.reveal-hint {
  font-size: 10px;
  color: var(--muted);
  font-family: "Barlow Condensed", sans-serif;
  letter-spacing: .1em;
  text-transform: uppercase;
}

/* Chinese answer — blurred until revealed */
.answer-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
  filter: blur(10px);
  transition: filter .3s;
  cursor: pointer;
  user-select: none;
}
.answer-wrap.revealed { filter: none; cursor: default; }
.answer-wrap:not(.revealed):hover { filter: blur(5px); }

/* The actual Chinese characters */
.zh-big {
  font-family: 'Noto Sans TC', sans-serif;
  font-size: 56px;
  font-weight: 700;
  color: var(--text);
  line-height: 1.1;
}

.pinyin-line {
  font-family: "IBM Plex Mono", monospace;
  font-size: 15px;
  color: var(--scm-blue);
  letter-spacing: .04em;
}

/* Reveal button */
.reveal-cta {
  background: var(--mid);
  border: 1px solid var(--bdr);
  color: var(--muted);
  font-family: "Barlow Condensed", sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  padding: 12px 32px;
  border-radius: 4px;
  cursor: pointer;
  transition: all .15s;
  display: flex;
  align-items: center;
  gap: 8px;
}
.reveal-cta:hover {
  border-color: var(--scm-blue);
  color: var(--scm-blue);
  background: var(--bg-hover);
}

/* Rating buttons */
.rating-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  margin-top: 4px;
}
.r-btn {
  padding: 14px 6px;
  border-radius: 6px;
  border: 1px solid var(--bdr);
  background: var(--surf);
  cursor: pointer;
  transition: all .15s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;
}
.r-btn:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
.r-btn .rn {
  font-family: "Barlow Condensed", sans-serif;
  font-size: 26px;
  font-weight: 800;
  line-height: 1;
}
.r-btn .rl {
  font-family: "Barlow Condensed", sans-serif;
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .1em;
  color: var(--muted);
}
.r-btn.q0 { border-color: var(--scm-warn); }
.r-btn.q0:hover { background: var(--bg-hover); }
.r-btn.q0 .rn { color: var(--scm-warn); }
.r-btn.q1 { border-color: var(--scm-accent); }
.r-btn.q1:hover { background: var(--bg-hover); }
.r-btn.q1 .rn { color: var(--scm-accent); }
.r-btn.q2 { border-color: var(--scm-blue); }
.r-btn.q2:hover { background: var(--bg-hover); }
.r-btn.q2 .rn { color: var(--scm-blue); }
.r-btn.q3 { border-color: var(--scm-green); }
.r-btn.q3:hover { background: var(--bg-hover); }
.r-btn.q3 .rn { color: var(--scm-green); }

/* Sentence example card */
.sentence-card {
  background: var(--surf);
  border: 1px solid var(--bdr);
  border-radius: 8px;
  padding: 22px 28px;
  margin-top: 4px;
}
.sentence-zh {
  font-family: 'Noto Sans TC', sans-serif;
  font-size: 16px;
  color: var(--text);
  margin-bottom: 6px;
  line-height: 1.7;
}
.sentence-en {
  font-size: 12px;
  color: var(--muted);
  line-height: 1.6;
}

/* Session complete box */
.complete-box {
  background: var(--surf);
  border: 1px solid var(--bdr);
  border-radius: 8px;
  padding: 60px;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  box-shadow: var(--shadow-sm);
}
.complete-box .big { font-size: 52px; }
.complete-box h2 {
  font-family: "Barlow Condensed", sans-serif;
  font-size: 24px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .06em;
}
.complete-box p { font-size: 13px; color: var(--muted); max-width: 360px; line-height: 1.8; }

/* ── LIBRARY TABLE ── */
.lib-toolbar {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}

/* Chinese cell */
.td-zh { font-family: 'Noto Sans TC', sans-serif; font-size: 18px; font-weight: 700; }
.td-py {
  font-family: "IBM Plex Mono", monospace;
  font-size: 10px;
  color: var(--scm-blue);
  margin-top: 2px;
}
.td-cat {
  font-family: "Barlow Condensed", sans-serif;
  font-size: 9px;
  font-weight: 700;
  color: var(--scm-green);
  border: 1px solid var(--scm-green);
  border-radius: 3px;
  padding: 2px 7px;
  letter-spacing: .08em;
  text-transform: uppercase;
  display: inline-block;
}
.td-due { font-family: "IBM Plex Mono", monospace; font-size: 10px; }
.due-now  { color: var(--scm-warn); }
.due-soon { color: var(--scm-blue); }
.due-ok   { color: var(--muted); }
.row-del {
  background: none;
  border: 1px solid var(--bdr);
  color: var(--muted);
  font-size: 11px;
  padding: 3px 9px;
  border-radius: 3px;
  cursor: pointer;
  transition: all .15s;
  font-family: "Barlow Condensed", sans-serif;
  font-weight: 700;
  letter-spacing: .06em;
}
.row-del:hover { border-color: var(--scm-warn); color: var(--scm-warn); }

/* ── IMPORT VIEW ── */
.import-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 32px;
}
.import-card {
  background: var(--surf);
  border: 1px solid var(--bdr);
  border-radius: 8px;
  padding: 24px;
  cursor: pointer;
  transition: all .2s;
  display: flex;
  flex-direction: column;
  gap: 10px;
  box-shadow: var(--shadow-sm);
}
.import-card:hover { border-color: var(--scm-blue); background: var(--bg-hover); }
.import-card.wide { grid-column: 1 / -1; }
.import-card .ic-icon { font-size: 28px; }
.import-card h3 {
  font-family: "Barlow Condensed", sans-serif;
  font-size: 15px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .07em;
}
.import-card p { font-size: 12px; color: var(--muted); line-height: 1.6; }

.import-panel { display: none; flex-direction: column; gap: 16px; }
.import-panel.open { display: flex; }

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 4px;
}
.panel-title {
  font-family: "Barlow Condensed", sans-serif;
  font-size: 18px;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .06em;
}

.import-hint {
  background: var(--mid);
  border: 1px solid var(--bdr);
  border-radius: 6px;
  padding: 14px;
  font-family: "IBM Plex Mono", monospace;
  font-size: 11px;
  color: var(--muted);
  line-height: 1.8;
}
.import-hint strong { color: var(--scm-blue); }

textarea.import-ta {
  background: var(--mid);
  border: 1px solid var(--bdr);
  color: var(--text);
  padding: 14px;
  border-radius: 6px;
  font-family: "IBM Plex Mono", monospace;
  font-size: 12px;
  line-height: 1.7;
  resize: vertical;
  min-height: 180px;
  outline: none;
  transition: border-color .15s;
  width: 100%;
}
textarea.import-ta:focus { border-color: var(--scm-blue); }
textarea.import-ta::placeholder { color: var(--muted); opacity: .5; }

.file-drop {
  border: 2px dashed var(--bdr);
  border-radius: 8px;
  padding: 40px;
  text-align: center;
  cursor: pointer;
  transition: all .2s;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10px;
}
.file-drop:hover,
.file-drop.dragover {
  border-color: var(--scm-blue);
  background: var(--bg-hover);
}
.file-drop .drop-icon { font-size: 32px; }
.file-drop p { font-size: 13px; color: var(--muted); }
.file-drop em {
  font-size: 11px;
  color: var(--muted);
  font-style: normal;
  font-family: "IBM Plex Mono", monospace;
  opacity: .6;
}
#csv-file-input { display: none; }

.preview-table-wrap {
  background: var(--mid);
  border: 1px solid var(--bdr);
  border-radius: 6px;
  overflow: auto;
  max-height: 240px;
}
.preview-table { width: 100%; border-collapse: collapse; font-size: 12px; }
.preview-table th {
  padding: 8px 12px;
  background: var(--dark);
  font-family: "Barlow Condensed", sans-serif;
  font-size: 9px;
  font-weight: 700;
  color: var(--muted);
  letter-spacing: .12em;
  text-transform: uppercase;
  position: sticky;
  top: 0;
}
.preview-table td {
  padding: 8px 12px;
  border-top: 1px solid var(--bdr);
  vertical-align: middle;
}
.preview-table .pv-zh { font-family: 'Noto Sans TC', sans-serif; font-size: 15px; font-weight: 700; }
.preview-table .pv-check { color: var(--scm-green); font-size: 14px; }
.preview-table .pv-warn  { color: var(--scm-accent); font-size: 12px; }

.import-actions { display: flex; gap: 10px; align-items: center; }
.import-count {
  font-family: "Barlow Condensed", sans-serif;
  font-size: 12px;
  font-weight: 700;
  color: var(--muted);
  letter-spacing: .06em;
  text-transform: uppercase;
}

/* ── TOAST ── */
.toast {
  position: fixed;
  bottom: 24px;
  right: 72px; /* offset from theme toggle */
  background: var(--surf);
  border: 1px solid var(--bdr);
  padding: 12px 20px;
  border-radius: 6px;
  font-size: 12px;
  font-family: "Barlow Condensed", sans-serif;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--text);
  transform: translateY(80px);
  opacity: 0;
  transition: all .3s;
  z-index: 1000;
  display: flex;
  align-items: center;
  gap: 8px;
  box-shadow: var(--shadow-md);
}
.toast.show { transform: translateY(0); opacity: 1; }
.toast.success .t-icon { color: var(--scm-green); }
.toast.error   .t-icon { color: var(--scm-warn); }

/* ── PROGRESS BAR — slim inline variant ── */
.study-prog-wrap {
  background: var(--bdr);
  border-radius: 3px;
  height: 3px;
  margin-bottom: 28px;
  overflow: hidden;
}
.study-prog-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--scm-blue), var(--scm-green));
  border-radius: 3px;
  transition: width .4s ease;
}

/* ── SCROLLBAR ── */
::-webkit-scrollbar { width: 5px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: var(--bdr); border-radius: 3px; }
</style>
</head>

<body>
<div class="app">

<!-- HEADER -->
<header class="srs-header">
  <div class="srs-logo">漢字 SRS <em>// vocab desk</em></div>
  <nav class="srs-nav">
    <button class="srs-tab active" onclick="switchView('study')" id="tab-study">▶ Study</button>
    <button class="srs-tab" onclick="switchView('library')" id="tab-library">Library</button>
    <button class="srs-tab" onclick="switchView('import')" id="tab-import">Import</button>
    <button class="srs-tab" onclick="switchView('add')" id="tab-add">+ Add Card</button>
  </nav>
</header>

<div class="srs-body">

  <!-- SIDEBAR -->
  <aside class="srs-sidebar">
    <div class="sidebar-section">Study</div>
    <button class="sidebar-btn active" onclick="switchView('study')" id="sb-study">
      <span class="icon">📖</span> Daily Review
    </button>
    <div class="sidebar-divider"></div>
    <div class="sidebar-section">Manage</div>
    <button class="sidebar-btn" onclick="switchView('library')" id="sb-library">
      <span class="icon">🗂</span> Library
    </button>
    <button class="sidebar-btn" onclick="switchView('add')" id="sb-add">
      <span class="icon">✏️</span> Add Single
    </button>
    <div class="sidebar-divider"></div>
    <div class="sidebar-section">Import</div>
    <button class="sidebar-btn" onclick="openImportPanel('paste')" id="sb-paste">
      <span class="icon">📋</span> Paste Table
    </button>
    <button class="sidebar-btn" onclick="openImportPanel('csv')" id="sb-csv">
      <span class="icon">📂</span> CSV / Excel
    </button>
    <div class="sidebar-divider"></div>
    <div class="sidebar-section">Export</div>
    <button class="sidebar-btn" onclick="exportCSV()">
      <span class="icon">💾</span> Export CSV
    </button>
  </aside>

  <!-- MAIN CONTENT -->
  <div class="srs-content">

    <!-- ── STUDY ── -->
    <div class="view active" id="view-study">

      <!-- Stats — uses SCM .stats-bar / .stat-card -->
      <div class="stats-bar" style="margin-bottom:24px;">
        <div class="stat-card stat-card--amber">
          <div class="stat-val" id="s-due">0</div>
          <div class="stat-lbl">Due Today</div>
        </div>
        <div class="stat-card">
          <div class="stat-val" id="s-total">0</div>
          <div class="stat-lbl">Total</div>
        </div>
        <div class="stat-card stat-card--green">
          <div class="stat-val" id="s-streak">0</div>
          <div class="stat-lbl">Streak</div>
        </div>
        <div class="stat-card stat-card--blue">
          <div class="stat-val" id="s-done">0</div>
          <div class="stat-lbl">Done Today</div>
        </div>
      </div>

      <!-- Progress bar -->
      <div class="study-prog-wrap">
        <div class="study-prog-bar" id="prog" style="width:0%"></div>
      </div>

      <!-- Card area -->
      <div id="area-card">
        <div class="study-card" id="study-card">
          <div class="card-tag" id="c-cat">—</div>
          <div class="card-pos" id="c-pos">— / —</div>
          <div class="en-prompt" id="c-en">—</div>
          <div class="reveal-hint">click answer to reveal · or press Space</div>
          <div class="answer-wrap" id="c-answer" onclick="revealAnswer()">
            <div class="zh-big" id="c-zh">???</div>
            <div class="pinyin-line" id="c-py">???</div>
          </div>
        </div>
        <div style="display:flex;justify-content:center;margin-bottom:16px;">
          <button class="reveal-cta" id="reveal-btn" onclick="revealAnswer()">
            <span>Reveal Answer</span><span>↵</span>
          </button>
        </div>
      </div>

      <!-- Rating -->
      <div class="rating-grid" id="area-rating" style="display:none">
        <button class="r-btn q0" onclick="rate(0)">
          <span class="rn">0</span><span class="rl">Blackout</span>
        </button>
        <button class="r-btn q1" onclick="rate(1)">
          <span class="rn">1</span><span class="rl">Hard</span>
        </button>
        <button class="r-btn q2" onclick="rate(2)">
          <span class="rn">2</span><span class="rl">Good</span>
        </button>
        <button class="r-btn q3" onclick="rate(3)">
          <span class="rn">3</span><span class="rl">Easy</span>
        </button>
      </div>

      <!-- Example sentence -->
      <div id="area-sentence" style="display:none;margin-top:12px;">
        <div class="sentence-card">
          <div class="sentence-zh" id="c-sent-zh">—</div>
          <div class="sentence-en" id="c-sent-en">—</div>
        </div>
      </div>

      <!-- Complete -->
      <div id="area-complete" style="display:none;margin-top:8px;">
        <div class="complete-box">
          <div class="big">✅</div>
          <h2>Session Complete</h2>
          <p>All cards reviewed. Your schedule is set — come back tomorrow to keep the streak alive.</p>
          <button class="btn btn-ghost" onclick="restartSession()" style="margin-top:8px;">
            Review Again
          </button>
        </div>
      </div>

      <!-- Empty -->
      <div id="area-empty" style="display:none;margin-top:8px;">
        <div class="empty-state">
          <div class="empty-icon">📭</div>
          <p>No cards yet. Use <strong>Import</strong> or <strong>Add Card</strong> to get started.</p>
        </div>
      </div>

    </div><!-- /view-study -->

    <!-- ── LIBRARY ── -->
    <div class="view" id="view-library">
      <div class="lib-toolbar">
        <!-- SCM .search-wrap -->
        <div class="search-wrap" style="flex:1">
          <input class="search-input" type="text"
            placeholder="Search cards…"
            oninput="renderLibrary()" id="lib-search">
        </div>
        <select class="field" style="width:auto;margin:0;"
          onchange="renderLibrary()" id="cat-filter">
          <option value="">All Categories</option>
          <option>PCB Design</option>
          <option>Product Development</option>
          <option>Supply Chain</option>
          <option>General</option>
        </select>
